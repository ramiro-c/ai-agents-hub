# Solo para correr el agente en LOCAL contra Vertex (via ADC).
# NO usar este archivo en `adk deploy` (GOOGLE_CLOUD_* choca con --project/--region).
# En Agent Engine, Vertex se configura solo (sin secretos).
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
