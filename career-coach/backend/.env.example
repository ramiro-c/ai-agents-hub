# Backend del Career Coach. Copiá este archivo a `backend/.env` y completá los valores.
# La auth a Vertex/Agent Engine es por ADC (local) o el service account (Cloud Run):
# NO va ninguna API key acá.

# Proyecto GCP (requerido).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Región del Agent Engine (opcional, default us-central1).
GOOGLE_CLOUD_LOCATION=us-central1

# Resource name completo que devuelve `adk deploy agent_engine` (requerido).
AGENT_ENGINE_RESOURCE=projects/YOUR_PROJECT_NUMBER/locations/YOUR_REGION/reasoningEngines/YOUR_ENGINE_ID

# Origen permitido para CORS en dev (opcional). En prod es mismo origen y no aplica.
FRONTEND_ORIGIN=http://localhost:5173
